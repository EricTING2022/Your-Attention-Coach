<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" />

    <queries>
        <package android:name="com.android.chrome" />
        <package android:name="com.google.android.apps.docs" />
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".AttentionCoachApplication"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AttentionCoach">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.AttentionCoach">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".platform.ReminderActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:showWhenLocked="true"
            android:theme="@style/Theme.AttentionCoach"
            android:turnScreenOn="true" />
        <activity
            android:name=".platform.ReentryLockscreenActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:showWhenLocked="true"
            android:theme="@style/Theme.AttentionCoach"
            android:turnScreenOn="true" />
        <service
            android:name=".platform.FocusMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
        <service
            android:name=".platform.AttentionCoachAccessibilityService"
            android:exported="true"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/attention_coach_accessibility_service" />
        </service>
        <receiver
            android:name=".platform.TaskReminderReceiver"
            android:exported="false" />
        <receiver
            android:name=".platform.ReentryReminderReceiver"
            android:exported="false" />
    </application>
</manifest>
